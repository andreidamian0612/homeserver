networks:
  mediaserver:
    name: mediaserver
    driver: bridge

services:
  jellyfin:
    image: jellyfin/jellyfin:latest
    container_name: jellyfin
    devices:
      - /dev/dri:/dev/dri
    restart: unless-stopped
    ports:
      - "8096:8096"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/jellyfin:/config
      - /media/storage/movies:/data/movies
      - /media/storage/tv:/data/tv
      - /media/storage/music:/data/music
    networks:
      - mediaserver

  radarr:
    image: lscr.io/linuxserver/radarr:latest
    container_name: radarr
    restart: unless-stopped
    ports:
      - "7878:7878"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/radarr:/config
      - /media/storage/movies:/movies
      - /media/storage/downloads:/downloads
    networks:
      - mediaserver

  sonarr:
    image: lscr.io/linuxserver/sonarr:latest
    container_name: sonarr
    restart: unless-stopped
    ports:
      - "8989:8989"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/sonarr:/config
      - /media/storage/tv:/tv
      - /media/storage/downloads:/downloads
    networks:
      - mediaserver

  lidarr:
    image: lscr.io/linuxserver/lidarr:latest
    container_name: lidarr
    restart: unless-stopped
    ports:
      - "8686:8686"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/lidarr:/config
      - /media/storage/music:/music
      - /media/storage/downloads:/downloads
    networks:
      - mediaserver

  prowlarr:
    image: lscr.io/linuxserver/prowlarr:latest
    container_name: prowlarr
    restart: unless-stopped
    ports:
      - "9696:9696"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/prowlarr:/config
    networks:
      - mediaserver

  qbittorrent:
    image: lscr.io/linuxserver/qbittorrent:latest
    container_name: qbittorrent
    restart: unless-stopped
    ports:
      - "8080:8080"
      - "6881:6881"
      - "6881:6881/udp"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
      - WEBUI_PORT=8080
    volumes:
      - /opt/mediaserver/config/qbittorrent:/config
      - /media/storage/downloads:/downloads
    networks:
      - mediaserver

  jellyseerr:
    image: seerr/seerr:v3.1.0
    container_name: jellyseerr
    restart: unless-stopped
    ports:
      - "5055:5055"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/jellyseerr:/app/config
    networks:
      - mediaserver

  bazarr:
    image: lscr.io/linuxserver/bazarr:latest
    container_name: bazarr
    restart: unless-stopped
    ports:
      - "6767:6767"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/bazarr:/config
      - /media/storage/movies:/movies
      - /media/storage/tv:/tv
    networks:
      - mediaserver

  mixarr:
    image: ghcr.io/aquantumofdonuts/mixarr:latest
    container_name: mixarr
    restart: unless-stopped
    ports:
      - "3010:80"
      - "3443:443"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Bucharest
      - SESSION_SECRET=b5b8be0e0ff7ee95616bc70197a1d406916c79648a0bb759f581679e98143fc0
      - BASE_URL=http://192.168.101.81:3010
    volumes:
      - /opt/mediaserver/config/mixarr:/data
    networks:
      - mediaserver

  homeassistant:
    image: ghcr.io/home-assistant/home-assistant:stable
    container_name: homeassistant
    restart: unless-stopped
    privileged: true
    network_mode: host
    environment:
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/homeassistant:/config
      - /dev:/dev

  portainer:
    image: portainer/portainer-ce:lts
    container_name: portainer
    restart: always
    ports:
      - "9443:9443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - portainer_data:/data


  kavita:
    image: jvmilazz0/kavita:latest
    container_name: kavita
    restart: unless-stopped
    ports:
      - "5000:5000"
    environment:
      - TZ=Europe/Bucharest
    volumes:
      - /opt/mediaserver/config/kavita:/kavita/config
      - /media/storage/books:/books
      - /media/storage/comics:/comics
    networks:
      - mediaserver

volumes:
  portainer_data:
